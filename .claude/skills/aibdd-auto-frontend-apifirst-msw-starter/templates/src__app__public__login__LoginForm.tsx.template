'use client'

import { useSearchParams } from 'next/navigation'
import { useRouter } from 'next/navigation'
import { useTranslations } from 'next-intl'
import { useCallback, useEffect, useState } from 'react'

/** 
 * Standard LoginForm Template with Social Login (Google/Microsoft)
 * Supports custom credentials and quick social auth mocks.
 */
export default function LoginForm() {
  const t = useTranslations('login')
  const router = useRouter()
  const searchParams = useSearchParams()
  const [username, setUsername] = useState('')
  const [password, setPassword] = useState('')
  const [error, setError] = useState<string | null>(null)
  const [pending, setPending] = useState(false)

  // Social Login Mock
  const onSocialLogin = useCallback(async (provider: 'google' | 'microsoft') => {
    setPending(true)
    setError(null)
    try {
      // Simulate OAuth flow
      const mockToken = `social-${provider}-token`
      const maxAge = 60 * 60 * 24
      document.cookie = `auth-token=${mockToken}; path=/; max-age=${maxAge}; SameSite=Lax`
      
      const from = searchParams.get('from') || '/dashboard'
      router.replace(from.startsWith('/') ? from : '/dashboard')
      router.refresh()
    } catch (err) {
      setError(err instanceof Error ? err.message : t('errorGeneric'))
    } finally {
      setPending(false)
    }
  }, [router, searchParams, t])

  const onSubmit = useCallback(
    async (e: React.FormEvent) => {
      e.preventDefault()
      setError(null)
      setPending(true)
      try {
        // ... creds login logic ...
      } catch (err) {
        setError(err instanceof Error ? err.message : t('errorGeneric'))
      } finally {
        setPending(false)
      }
    },
    [username, password, router, searchParams, t]
  )

  return (
    <div className="flex items-center justify-center min-h-screen bg-background p-4">
      <div className="w-full max-w-md space-y-8 bg-surface p-8 rounded-2xl border border-border shadow-lg">
        <div>
          <h1 className="text-2xl font-semibold tracking-tight text-foreground">{t('title')}</h1>
          <p className="mt-2 text-sm text-muted-foreground">{t('subtitle')}</p>
        </div>

        {/* Social Login Buttons */}
        <div className="grid grid-cols-2 gap-3">
          <button
            onClick={() => onSocialLogin('google')}
            disabled={pending}
            className="flex items-center justify-center h-10 gap-2 px-4 text-sm font-medium transition bg-background border border-border rounded-md hover:bg-muted/50 disabled:opacity-50"
          >
            {/* Google Icon SVG */}
            <svg className="w-4 h-4" viewBox="0 0 24 24">
               <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
               <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
               <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
               <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            <span>Google</span>
          </button>
          <button
            onClick={() => onSocialLogin('microsoft')}
            disabled={pending}
            className="flex items-center justify-center h-10 gap-2 px-4 text-sm font-medium transition bg-background border border-border rounded-md hover:bg-muted/50 disabled:opacity-50"
          >
            {/* Microsoft Icon SVG */}
             <svg className="w-4 h-4" viewBox="0 0 24 24">
                <rect x="1" y="1" width="10" height="10" fill="#f25022"/>
                <rect x="13" y="1" width="10" height="10" fill="#7fbb00"/>
                <rect x="1" y="13" width="10" height="10" fill="#00a1f1"/>
                <rect x="13" y="13" width="10" height="10" fill="#ffbb00"/>
             </svg>
            <span>Microsoft</span>
          </button>
        </div>

        <div className="relative flex items-center py-2">
          <div className="flex-grow border-t border-border"></div>
          <span className="flex-shrink mx-4 text-xs text-muted-foreground uppercase">{t('social.or')}</span>
          <div className="flex-grow border-t border-border"></div>
        </div>

        <form className="space-y-4" onSubmit={onSubmit}>
          {/* ... username/password fields ... */}
          <button
            type="submit"
            disabled={pending}
            className="w-full ui-btn-primary"
          >
            {pending ? t('submitting') : t('submit')}
          </button>
        </form>
      </div>
    </div>
  )
}
