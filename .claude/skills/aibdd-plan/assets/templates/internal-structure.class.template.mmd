classDiagram
    class BoundaryAPI {
      +handle_request()
    }
    class ApplicationService {
      +execute_operation()
    }
    class Repository {
      +load_state()
      +save_state()
    }
    class ProviderAdapter {
      +call_provider()
    }
    class ResponseVerifier {
      +verify_response()
    }
    class StateVerifier {
      +verify_state()
    }

    BoundaryAPI --> ApplicationService
    ApplicationService --> Repository
    ApplicationService --> ProviderAdapter
    ApplicationService --> ResponseVerifier
    StateVerifier --> Repository
