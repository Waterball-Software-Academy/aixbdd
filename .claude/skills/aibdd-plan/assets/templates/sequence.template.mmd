sequenceDiagram
    %% Render one ImplementationPath only.
    %% Filename: <path.slug>.<path.kind>.sequence.mmd
    %% Required participants: actor, boundary entry, application service, repositories.
    %% Include provider only when the path touches an external edge.
    actor Actor as <actor label>
    participant BoundaryAPI as <boundary entry>
    participant ApplicationService as <application service>
    participant Repository as <repository or state store>
    participant Provider as <external provider if any>

    Actor->>BoundaryAPI: <boundary operation trigger>
    BoundaryAPI->>ApplicationService: <command/query>
    ApplicationService->>Repository: <state read/write or validation>
    Repository-->>ApplicationService: <state result>
    ApplicationService->>Provider: <provider operation if this path has one>
    Provider-->>ApplicationService: <provider response or failure>
    ApplicationService-->>BoundaryAPI: <operation result or failure reason>
    BoundaryAPI-->>Actor: <response verifier candidate>
